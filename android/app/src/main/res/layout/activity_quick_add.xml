<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="빠른 지출 추가"
        android:textColor="#E8EAED"
        android:textStyle="bold"
        android:textSize="18sp" />

    <EditText
        android:id="@+id/qa_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="금액"
        android:textColorHint="#6B7280"
        android:textColor="#E8EAED"
        android:textSize="20sp"
        android:inputType="number"
        android:backgroundTint="#4F8CFF" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/qa_cats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <EditText
        android:id="@+id/qa_memo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="내용 (선택, 최대 20자)"
        android:textColorHint="#6B7280"
        android:textColor="#E8EAED"
        android:textSize="16sp"
        android:inputType="text"
        android:maxLength="20"
        android:backgroundTint="#2C313C" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/qa_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="취소"
            android:textColor="#E8EAED"
            android:background="@drawable/widget_add_bg_ghost" />

        <Button
            android:id="@+id/qa_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="저장"
            android:textColor="#FFFFFF"
            android:background="@drawable/widget_save_bg" />
    </LinearLayout>

</LinearLayout>

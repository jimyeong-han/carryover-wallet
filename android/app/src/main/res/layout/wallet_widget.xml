<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 배경: 흰색 라운드 셰이프에 색 필터(색상) + 이미지 알파(투명도)를 코드에서 적용 -->
    <ImageView
        android:id="@+id/widget_bg_img"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/widget_bg_shape"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘 쓸 수 있는 돈"
                android:textColor="#9AA0AC"
                android:textSize="12sp"
                android:shadowColor="#80000000"
                android:shadowRadius="3" />

            <TextView
                android:id="@+id/widget_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="-"
                android:textColor="#37D67A"
                android:textStyle="bold"
                android:textSize="24sp"
                android:shadowColor="#80000000"
                android:shadowRadius="3" />

            <TextView
                android:id="@+id/widget_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textColor="#9AA0AC"
                android:textSize="11sp"
                android:shadowColor="#80000000"
                android:shadowRadius="3" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_add"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:text="＋"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/widget_add_bg"
            android:contentDescription="빠른 지출 추가" />
    </LinearLayout>
</FrameLayout>

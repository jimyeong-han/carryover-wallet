<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="위젯 배경 설정"
        android:textColor="#E8EAED"
        android:textStyle="bold"
        android:textSize="18sp" />

    <!-- 미리보기 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/config_preview_checker">

        <ImageView
            android:id="@+id/cfg_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/widget_bg_shape"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="14dp"
            android:text="12,000원"
            android:textColor="#37D67A"
            android:textStyle="bold"
            android:textSize="20sp"
            android:shadowColor="#80000000"
            android:shadowRadius="3" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="배경색"
        android:textColor="#9AA0AC"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/cfg_colors"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal" />

    <TextView
        android:id="@+id/cfg_alpha_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="투명도 0%"
        android:textColor="#9AA0AC"
        android:textSize="13sp" />

    <SeekBar
        android:id="@+id/cfg_alpha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/cfg_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="취소"
            android:textColor="#E8EAED"
            android:background="@drawable/widget_add_bg_ghost" />

        <Button
            android:id="@+id/cfg_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="저장"
            android:textColor="#FFFFFF"
            android:background="@drawable/widget_save_bg" />
    </LinearLayout>
</LinearLayout>

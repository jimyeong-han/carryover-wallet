# 릴리스 서명 설정 예시.
# 이 파일을 복사해서 android/keystore.properties 로 만들고 값을 채우세요.
# (keystore.properties 와 *.jks 는 git 에 올라가지 않습니다)
#
# storeFile 경로는 android/ 폴더 기준 상대경로 또는 절대경로.
# 예) 키스토어를 android/ 안에 두면 storeFile=carryover-release.jks

storeFile=carryover-release.jks
storePassword=여기에_키스토어_비밀번호
keyAlias=carryover
keyPassword=여기에_키_비밀번호
